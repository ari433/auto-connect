# ─────────────────────────────────────────────────────────────
#  AUTO CONNECT — environment configuration
#  Copy to `.env` and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Catalogue source ─────────────────────────────────────────
# The site can run in two modes:
#   • "live" → reads cars straight from Carapis (NO database needed)
#   • "db"   → reads from a synced PostgreSQL catalogue
# Leave CATALOG_SOURCE unset to auto-pick: "db" if DATABASE_URL is set, else "live".
# CATALOG_SOURCE="live"

# Database (PostgreSQL) — OPTIONAL. Only needed for "db" mode, leads, and admin.
# In live mode you can leave this empty and deploy with just a Carapis key.
DATABASE_URL=""

# Public site URL (used for SEO, canonical URLs, sitemap)
NEXT_PUBLIC_SITE_URL="https://autoconnect-ks.com"

# ── Carapis (live Encar inventory feed) ──────────────────────
# Server-side ONLY. The key is never exposed to the browser.
# Free Tier works with NO key (latest ~1000 vehicles). Drop in a
# paid key here with zero frontend changes.
CARAPIS_API_KEY=""
# The live catalog endpoint (page-based). Override only if Carapis versions it.
# CARAPIS_BASE_URL="https://api.carapis.com"
# CARAPIS_VEHICLES_PATH="/apix/catalog_api/vehicles/"
# Only pull available (unsold) listings. Default false (include all).
# CARAPIS_AVAILABLE_ONLY="false"
# CARAPIS_MAX_VEHICLES="1000"
# CARAPIS_PAGE_SIZE="100"
# CARAPIS_TIMEOUT_MS="20000"
# Set to "false" to disable the offline snapshot fallback in production.
# CARAPIS_ALLOW_FALLBACK="true"

# Inventory serving mode for GET /api/inventory:
#   "live" → call Carapis on each request (default; sold cars drop off)
#   "db"   → serve from the synced catalogue (instant; needs the cron below)
INVENTORY_SOURCE="live"

# Protects the scheduled sync route (/api/cron/inventory).
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""

# ── Pricing engine ───────────────────────────────────────────
# KRW → EUR conversion rate (shared by the Car feed and pricing engine).
PRICING_FX_KRW_EUR="0.00069"
# Optional Carapis-specific override for the Car feed's priceEUR.
# CARAPIS_KRW_EUR_RATE="0.00069"
PRICING_LOGISTICS_EUR="1650"
PRICING_DUTY_RATE="0.1"
PRICING_VAT_RATE="0.18"
PRICING_COMPLIANCE_EUR="450"
PRICING_MARGIN_RATE="0.12"
PRICING_MIN_MARGIN_EUR="1800"
PRICING_ROUNDING_EUR="100"
# Flat markup added to every customer-facing price (demo/promo lever). 0 = off.
PRICING_DEMO_MARKUP_EUR="0"

# ── Admin area ───────────────────────────────────────────────
# When set, the admin dashboard + mutating admin APIs require this token.
# Leave empty in local dev to keep the panel open.
ADMIN_TOKEN=""
