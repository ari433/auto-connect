# ─────────────────────────────────────────────────────────────
#  AUTO CONNECT — environment configuration
#  Copy to `.env` and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Catalogue source ─────────────────────────────────────────
# The site can run in two modes:
#   • "live" → reads cars straight from Carapis (NO database needed)
#   • "db"   → reads from a synced PostgreSQL catalogue
# Leave CATALOG_SOURCE unset to auto-pick: "db" if DATABASE_URL is set, else "live".
# CATALOG_SOURCE="live"

# Database (PostgreSQL). Set this to run the full catalogue in "db" mode.
# When set, the app serves from the database once it holds inventory, and falls
# back to the live Carapis feed automatically while it is empty or unreachable.
# First-time setup, then the whole Encar catalogue is browsable + searchable:
#   1) npm run prisma:deploy      # apply migrations to the database
#   2) npm run db:sync            # one-shot full sync (streams the catalogue in)
# The scheduled cron (/api/cron/inventory) keeps it fresh afterwards.
# Leave empty to run database-free "live" mode with only a Carapis key.
DATABASE_URL=""

# Public site URL (used for SEO, canonical URLs, sitemap)
NEXT_PUBLIC_SITE_URL="https://autoconnect-korea.com"

# ── Carapis (live Encar inventory feed) ──────────────────────
# Server-side ONLY. The key is never exposed to the browser.
# REQUIRED for real inventory: the catalog endpoint returns HTTP 401
# ("api_key_required") without it. With no key the site serves only the
# bundled offline snapshot (dev convenience) — never real Encar vehicles.
# Get a key from carapis.com and drop it in here; zero frontend changes.
CARAPIS_API_KEY=""
# The live catalog endpoint (page-based). Override only if Carapis versions it.
# CARAPIS_BASE_URL="https://api.carapis.com"
# CARAPIS_VEHICLES_PATH="/apix/catalog_api/vehicles/"
# Only pull available (unsold) listings. Default false (include all).
# CARAPIS_AVAILABLE_ONLY="false"
# CARAPIS_MAX_VEHICLES="1000"
# CARAPIS_PAGE_SIZE="100"
# CARAPIS_TIMEOUT_MS="20000"
# Set to "false" to disable the offline snapshot fallback in production.
# CARAPIS_ALLOW_FALLBACK="true"
# Full-sync paging (db mode). The endpoint caps page_size at 200, so a large
# page keeps the whole ~120k catalogue to ~600 requests. Defaults suit that.
# CARAPIS_SYNC_PAGE_SIZE="200"
# CARAPIS_SYNC_MAX_VEHICLES="200000"
# Detail pages enrich with full specs from the per-vehicle endpoint (~3s);
# this bounds the wait, then serves listing data. Result is cached.
# CATALOG_DETAIL_TIMEOUT_MS="8000"

# Inventory serving mode for GET /api/inventory:
#   "live" → call Carapis on each request (default; sold cars drop off)
#   "db"   → serve from the synced catalogue (instant; needs the cron below)
INVENTORY_SOURCE="live"

# Protects the scheduled sync route (/api/cron/inventory).
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""

# ── Pricing engine ───────────────────────────────────────────
# USD → EUR conversion rate (the live catalog prices vehicles in USD).
PRICING_FX_USD_EUR="0.92"
# KRW → EUR conversion rate (used only by the legacy landed-cost engine).
PRICING_FX_KRW_EUR="0.00069"
# Optional Carapis-specific override for the Car feed's priceEUR.
# CARAPIS_KRW_EUR_RATE="0.00069"
PRICING_LOGISTICS_EUR="1650"
PRICING_DUTY_RATE="0.1"
PRICING_VAT_RATE="0.18"
PRICING_COMPLIANCE_EUR="450"
PRICING_MARGIN_RATE="0.12"
PRICING_MIN_MARGIN_EUR="1800"
PRICING_ROUNDING_EUR="100"
# Flat markup added to every customer-facing price (demo/promo lever). 0 = off.
# NB: the live (Carapis) catalogue uses the stepped marketplace markup below and
# ignores this flat lever; it applies only to the legacy KRW landed-cost engine.
PRICING_DEMO_MARKUP_EUR="0"

# ── Marketplace markup (live catalogue) ──────────────────────
# The original Encar selling price is NEVER shown. Every customer price is the
# imported base price (EUR) plus a fixed margin:
#   base <= threshold  →  base + LOW
#   base >  threshold  →  base + HIGH
# Defaults match the commercial rule: ≤€10,000 → +€2,000, else +€3,000.
# PRICING_MARKUP_THRESHOLD_EUR="10000"
# PRICING_MARKUP_LOW_EUR="2000"
# PRICING_MARKUP_HIGH_EUR="3000"

# ── Admin area ───────────────────────────────────────────────
# When set, the admin dashboard + mutating admin APIs require this token.
# Leave empty in local dev to keep the panel open.
ADMIN_TOKEN=""
